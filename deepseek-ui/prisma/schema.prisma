generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TradingSignal {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now())
  pair             String
  action           String
  confidence       Float
  entryPrice       Float
  stopLoss         Float
  takeProfit       Float
  positionSize     Float
  reasoning        String
  rsi              Float?
  rsiSignal        String?
  macdTrend        String?
  bbPosition       String?
  emaTrend         String?
  volumeSpike      Boolean?
  stochRsiK        Float?
  stochRsiD        Float?
  stochRsiSignal   String?
  atrPercent       Float?
  obvTrend         String?
  ichimokuSignal   String?
  volatilityLevel  String?
  fearGreedValue   Int?
  fearGreedClass   String?
  redditSentiment  Float?
  overallSentiment String?
  executed         Boolean  @default(false)
  txid             String?

  @@index([pair, createdAt])
  @@index([createdAt])
}

model Trade {
  id            Int       @id @default(autoincrement())
  createdAt     DateTime  @default(now())
  closedAt      DateTime?
  pair          String
  type          String
  entryPrice    Float
  exitPrice     Float?
  volume        Float
  stopLoss      Float
  takeProfit    Float
  pnl           Float?
  pnlPercent    Float?
  status        String    @default("open")
  txid          String?   // parentOrderId (entry order)
  closeTxid     String?
  closeReason   String?
  slOrderId          Int?      // IB stop-loss child order ID — survives app restarts
  tpOrderId          Int?      // IB take-profit child order ID — survives app restarts
  expectedProfitUSD  Float?    // Dollar profit if TP hits: volume × (takeProfit − entryPrice)
  expectedLossUSD    Float?    // Dollar loss if SL hits:   volume × (entryPrice − stopLoss)
  riskRewardRatio    Float?    // expectedProfitUSD / expectedLossUSD

  @@index([pair, createdAt])
  @@index([status])
}

model PortfolioSnapshot {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  totalValue     Float    // NetLiquidation_CAD
  cadCash        Float?   // TotalCashValue_CAD
  unrealizedPnl  Float?   // UnrealizedPnL_CAD
  realizedPnl    Float?   // RealizedPnL_CAD
  buyingPower    Float?   // BuyingPower_CAD

  @@index([createdAt])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  type      String
  message   String
  pair      String?
  data      Json?

  @@index([createdAt])
  @@index([type])
  @@index([pair])
  // Composite indexes for common range queries:
  //   - filter by type within a time window (e.g. "all errors in the last 24h")
  //   - filter by pair within a time window (e.g. "all AAPL activity today")
  @@index([createdAt, type])
  @@index([pair, createdAt])
}

model MarketIntelligence {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now())
  pair              String
  fearGreedValue    Int
  fearGreedClass    String
  redditSentiment   Float
  overallSentiment  String
  overallScore      Float
  coinDeskHeadlines Json?
  redditPosts       Json?
  consensusSignal   String?
  buyCount          Int?
  sellCount         Int?
  holdCount         Int?
  avgConfidence     Float?

  @@index([pair, createdAt])
}

model PriceCandle {
  id        Int      @id @default(autoincrement())
  pair      String
  interval  Int
  time      Int
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  createdAt DateTime @default(now())

  @@unique([pair, interval, time])
  @@index([pair, interval, time])
}

model ChatConversation {
  id        Int           @id @default(autoincrement())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  title     String?
  model     String
  messages  ChatMessage[]

  @@index([createdAt])
}

model ChatMessage {
  id             Int              @id @default(autoincrement())
  createdAt      DateTime         @default(now())
  conversationId Int
  role           String
  content        String
  tokens         Int?
  error          Boolean          @default(false)
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  type      String   // 'trade_executed', 'trade_failed', 'trade_closed', 'ib_disconnected', 'bot_stopped', 'alert_*'
  title     String
  message   String
  pair      String?  // nullable — not all alerts relate to a specific stock
  read      Boolean  @default(false)

  @@index([createdAt])        // used by retention cleanup (DELETE WHERE createdAt < cutoff)
  @@index([read])             // used by unread count query
  @@index([pair, createdAt])  // used by per-stock notification history
}

model BotState {
  id          Int      @id @default(1)
  isRunning   Boolean  @default(false)
  startedAt   DateTime?
  stoppedAt   DateTime?
  config      Json?
  updatedAt   DateTime @updatedAt
}

model BotCache {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
