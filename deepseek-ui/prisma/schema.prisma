generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TradingSignal {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now())
  pair             String
  action           String
  confidence       Float
  entryPrice       Float
  stopLoss         Float
  takeProfit       Float
  positionSize     Float
  reasoning        String
  rsi              Float?
  rsiSignal        String?
  macdTrend        String?
  bbPosition       String?
  emaTrend         String?
  volumeSpike      Boolean?
  stochRsiK        Float?
  stochRsiD        Float?
  stochRsiSignal   String?
  atrPercent       Float?
  obvTrend         String?
  ichimokuSignal   String?
  volatilityLevel  String?
  fearGreedValue   Int?
  fearGreedClass   String?
  redditSentiment  Float?
  overallSentiment String?
  executed         Boolean  @default(false)
  txid             String?

  @@index([pair, createdAt])
  @@index([createdAt])
}

model Trade {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  closedAt    DateTime?
  pair        String
  type        String
  entryPrice  Float
  exitPrice   Float?
  volume      Float
  stopLoss    Float
  takeProfit  Float
  pnl         Float?
  pnlPercent  Float?
  status      String    @default("open")
  txid        String?
  closeTxid   String?
  closeReason String?

  @@index([pair, createdAt])
  @@index([status])
}

model PortfolioSnapshot {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  totalValue Float
  cadBalance Float    @default(0)
  btcBalance Float    @default(0)
  ethBalance Float    @default(0)
  solBalance Float    @default(0)
  ltcBalance Float    @default(0)
  xrpBalance Float    @default(0)
  otherValue Float    @default(0)
  btcPrice   Float?
  ethPrice   Float?
  solPrice   Float?

  @@index([createdAt])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  type      String
  message   String
  pair      String?
  data      Json?

  @@index([createdAt])
  @@index([type])
  @@index([pair])
}

model MarketIntelligence {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now())
  pair              String
  fearGreedValue    Int
  fearGreedClass    String
  redditSentiment   Float
  overallSentiment  String
  overallScore      Float
  coinDeskHeadlines Json?
  redditPosts       Json?
  consensusSignal   String?
  buyCount          Int?
  sellCount         Int?
  holdCount         Int?
  avgConfidence     Float?

  @@index([pair, createdAt])
}

model PriceCandle {
  id        Int      @id @default(autoincrement())
  pair      String
  interval  Int
  time      Int
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  createdAt DateTime @default(now())

  @@unique([pair, interval, time])
  @@index([pair, interval, time])
}

model ChatConversation {
  id        Int           @id @default(autoincrement())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  title     String?
  model     String
  messages  ChatMessage[]

  @@index([createdAt])
}

model ChatMessage {
  id             Int              @id @default(autoincrement())
  createdAt      DateTime         @default(now())
  conversationId Int
  role           String
  content        String
  tokens         Int?
  error          Boolean          @default(false)
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model BotState {
  id          Int      @id @default(1)
  isRunning   Boolean  @default(false)
  startedAt   DateTime?
  stoppedAt   DateTime?
  config      Json?
  updatedAt   DateTime @updatedAt
}
