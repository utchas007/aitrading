// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Trading Signals ────────────────────────────────────────────────────────
model TradingSignal {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now())
  pair            String
  action          String   // buy | sell | hold
  confidence      Float
  entryPrice      Float
  stopLoss        Float
  takeProfit      Float
  positionSize    Float
  reasoning       String   @db.Text
  // Technical indicators snapshot
  rsi             Float?
  rsiSignal       String?
  macdTrend       String?
  bbPosition      String?
  emaTrend        String?
  volumeSpike     Boolean?
  // Enhanced indicators
  stochRsiK       Float?
  stochRsiD       Float?
  stochRsiSignal  String?
  atrPercent      Float?
  obvTrend        String?
  ichimokuSignal  String?
  volatilityLevel String?
  // Sentiment
  fearGreedValue  Int?
  fearGreedClass  String?
  redditSentiment Float?
  overallSentiment String?
  // Execution
  executed        Boolean  @default(false)
  txid            String?

  @@index([pair, createdAt])
  @@index([createdAt])
}

// ─── Executed Trades ────────────────────────────────────────────────────────
model Trade {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  closedAt    DateTime?
  pair        String
  type        String   // buy | sell
  entryPrice  Float
  exitPrice   Float?
  volume      Float
  stopLoss    Float
  takeProfit  Float
  pnl         Float?
  pnlPercent  Float?
  status      String   @default("open") // open | closed | stopped
  txid        String?
  closeTxid   String?
  closeReason String?  // take_profit | stop_loss | manual

  @@index([pair, createdAt])
  @@index([status])
}

// ─── Portfolio Snapshots ─────────────────────────────────────────────────────
model PortfolioSnapshot {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  totalValue  Float    // Total portfolio value in CAD
  cadBalance  Float    @default(0)
  btcBalance  Float    @default(0)
  ethBalance  Float    @default(0)
  solBalance  Float    @default(0)
  ltcBalance  Float    @default(0)
  xrpBalance  Float    @default(0)
  otherValue  Float    @default(0)
  btcPrice    Float?
  ethPrice    Float?
  solPrice    Float?

  @@index([createdAt])
}

// ─── Bot Activity Log ────────────────────────────────────────────────────────
model ActivityLog {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  type      String   // info | warning | error | success | analyzing | executing | calculating | completed
  message   String   @db.Text
  pair      String?
  data      Json?    // Optional structured data

  @@index([createdAt])
  @@index([type])
  @@index([pair])
}

// ─── Market Intelligence Snapshots ──────────────────────────────────────────
model MarketIntelligence {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now())
  pair             String
  fearGreedValue   Int
  fearGreedClass   String
  redditSentiment  Float
  overallSentiment String
  overallScore     Float
  coinDeskHeadlines Json?   // Array of headline strings
  redditPosts      Json?    // Array of post objects
  // Multi-timeframe consensus
  consensusSignal  String?
  buyCount         Int?
  sellCount        Int?
  holdCount        Int?
  avgConfidence    Float?

  @@index([pair, createdAt])
}

// ─── Price Candles Cache ─────────────────────────────────────────────────────
model PriceCandle {
  id        Int      @id @default(autoincrement())
  pair      String
  interval  Int      // minutes
  time      Int      // Unix timestamp
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  createdAt DateTime @default(now())

  @@unique([pair, interval, time])
  @@index([pair, interval, time])
}

// ─── Chat Conversations ──────────────────────────────────────────────────────
model ChatConversation {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String?  // Auto-generated from first message
  model     String   // e.g. "deepseek-r1:14b"
  messages  ChatMessage[]

  @@index([createdAt])
}

model ChatMessage {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  conversationId Int
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String   // "user" | "assistant" | "system"
  content        String   @db.Text
  tokens         Int?     // Token count for this message
  error          Boolean  @default(false)

  @@index([conversationId, createdAt])
}
