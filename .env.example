# AI Trading Bot - Environment Variables Template
# Copy this file to deepseek-ui/.env.local and fill in your actual values

# Kraken API Credentials
# Get these from: https://www.kraken.com/u/security/api
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_PRIVATE_KEY=your_kraken_private_key_here

# Ollama Configuration (for DeepSeek R1 AI)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:14b

# Optional: World Monitor Integration
# If you want to use World Monitor features, configure these:
# WORLDMONITOR_URL=http://localhost:3000
